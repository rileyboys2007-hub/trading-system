//@version=6
// ═══════════════════════════════════════════════════════════════════════════
// NQ Trading System — Sweep & Playbook Scanner  v2.0
// ═══════════════════════════════════════════════════════════════════════════
//
// v2.0 enhancements (powered by Free Plan Unlocked research):
//   • VWAP + Anchored VWAP — signal context + optional sweep filter
//   • MTF Trend Context (15m/1H/4H) — bonus scoring for aligned signals
//   • Session Kill Zones (PDT) — Asia/London/NY shading
//   • MA Suite — EMA 9/21/50 + SMA 200 overlay
//   • Volume Profile (approx., off by default)
//   • MTF Dashboard — mini table showing 15m/1H/4H trend + RSI + VWAP pos
//   • Enhanced webhook JSON: now includes "vwap" and "mtf" fields
//
// SETUP:
//   1. Add to NQ1! on the 5-minute chart
//   2. Set Webhook Secret in indicator settings (matches VPS WEBHOOK_SECRET)
//   3. Create ONE alert → "Any alert() function call"
//      Webhook URL: http://187.124.235.75/webhook
//
// WEBHOOK PAYLOAD:
//   { "secret":"...", "symbol":"NQ=F", "timeframe":"5",
//     "setup":"PDH_SWEEP_REVERSAL_SHORT", "entry":21450.25,
//     "sl":21475.00, "tp1":21413.00, "tp2":21375.75,
//     "vwap":"below", "mtf":"4H:bear|1H:bear|15m:bear",
//     "t5":"BEARISH", "t15":"BEARISH", "t60":"NEUTRAL",
//     "notes":"PDH swept 3.5pts rej=85%" }
//
// t5/t15/t60 = EMA 9 vs 21 trend on 5m / 15m / 1H timeframes (TradingView-native,
//              replaces the delayed Yahoo Finance trend fetch on the server side)
//
// ═══════════════════════════════════════════════════════════════════════════
indicator("NQ Trading System — Sweep & Playbook Scanner v2.0",
     overlay          = true,
     max_labels_count = 500,
     max_lines_count  = 500,
     max_boxes_count  = 500,
     max_bars_back    = 500)


// ═══════════════════════════════════════════════════════════════════════════
// ── INPUTS
// ═══════════════════════════════════════════════════════════════════════════

string i_secret   = input.string("CHANGE_ME", "Webhook Secret",      tooltip="Must match WEBHOOK_SECRET in your VPS .env file")
string i_symbol   = input.string("NQ=F",       "Symbol for payload", tooltip="Yahoo Finance format stored in backend")

int   i_atr_len   = input.int  (14,   "ATR Period",         minval=5, maxval=50,   group="Risk")
float i_atr_mult  = input.float(2.0,  "ATR × SL",          minval=1.0, maxval=4.0, step=0.5, group="Risk")
int   i_sl_floor  = input.int  (14,   "SL Floor (pts)",    minval=5,  maxval=30,   group="Risk")
int   i_sl_cap    = input.int  (55,   "SL Cap (pts)",      minval=30, maxval=120,  group="Risk")

float i_min_sweep = input.float(4.0,  "Min Sweep (pts)",   minval=0.25, step=0.25, group="Sweeps", tooltip="Min wick past level to qualify")
float i_min_rej   = input.float(0.60, "Min Rejection (0–1)", minval=0.1, maxval=0.9, step=0.05, group="Sweeps", tooltip="Snap-back strength required")
bool  i_vwap_filt = input.bool (true,  "VWAP Filter — sweeps align with VWAP side", group="Sweeps", tooltip="Shorts only fire below VWAP; longs only above")

bool  i_rth_only  = input.bool (true,  "Session alerts only (9:30 AM–10:00 PM ET / 7 PM PDT)", group="Filters")

bool  i_show_lvl  = input.bool (true,  "Show Key Levels",               group="Display")
bool  i_show_lbl  = input.bool (true,  "Show Signal Labels",            group="Display")
bool  i_show_ma   = input.bool (true,  "Show MA Suite (EMA 9/21/50, SMA 200)", group="Display")
bool  i_show_vwap = input.bool (true,  "Show VWAP + Anchored VWAP",    group="Display")
bool  i_show_sess = input.bool (true,  "Show Session Kill Zones (PDT)", group="Display")
bool  i_show_mtf  = input.bool (true,  "Show MTF Trend Dashboard",      group="Display")
bool  i_show_vp   = input.bool (false, "Show Volume Profile (approx.)", group="Display")

int   avwapYear   = input.int  (2025,  "Anchored VWAP Year",  minval=2020, maxval=2030, group="VWAP")
int   avwapMonth  = input.int  (1,     "Anchored VWAP Month", minval=1,    maxval=12,   group="VWAP")
int   vpLb        = input.int  (200,   "VP Lookback bars",    minval=20,   maxval=500,  group="Volume Profile")
int   vpBins      = input.int  (24,    "VP Rows",             minval=6,    maxval=60,   group="Volume Profile")


// ═══════════════════════════════════════════════════════════════════════════
// ── SESSION DETECTION
// ═══════════════════════════════════════════════════════════════════════════

bool is_rth        = not na(time(timeframe.period, "0930-2200", "America/New_York"))
bool is_or_window  = not na(time(timeframe.period, "0930-1000", "America/New_York"))
bool is_premarket  = not na(time(timeframe.period, "0400-0930", "America/New_York"))
bool rth_just_open = is_rth and not is_rth[1]
bool new_day       = ta.change(time("D")) != 0
bool in_session    = not i_rth_only or is_rth

string kz_tz = "America/Los_Angeles"
bool inAsia  = i_show_sess and not na(time(timeframe.period, "1700-0200", kz_tz))
bool inLon   = i_show_sess and not na(time(timeframe.period, "0200-0500", kz_tz))
bool inNY    = i_show_sess and not na(time(timeframe.period, "0630-1000", kz_tz))


// ═══════════════════════════════════════════════════════════════════════════
// ── KEY LEVELS
// ═══════════════════════════════════════════════════════════════════════════

[pdh, pdl, pdc] = request.security(syminfo.tickerid, "D", [high[1], low[1], close[1]], lookahead=barmerge.lookahead_on)

var float _orh = na
var float _orl = na
var bool  or_ready = false

if new_day
    _orh     := na
    _orl     := na
    or_ready := false

if is_or_window
    _orh := na(_orh) ? high : math.max(_orh, high)
    _orl := na(_orl) ? low  : math.min(_orl, low)
else if is_rth and not na(_orh) and not or_ready
    or_ready := true

float orh = _orh
float orl = _orl

var float _pmh_build = na
var float _pml_build = na
var float pmh = na
var float pml = na

if new_day
    _pmh_build := na
    _pml_build := na

if is_premarket
    _pmh_build := na(_pmh_build) ? high : math.max(_pmh_build, high)
    _pml_build := na(_pml_build) ? low  : math.min(_pml_build, low)

if rth_just_open and not na(_pmh_build)
    pmh := _pmh_build
    pml := _pml_build

var float _onh_build = na
var float _onl_build = na
var float onh = na
var float onl = na

if not is_rth
    _onh_build := na(_onh_build) ? high : math.max(_onh_build, high)
    _onl_build := na(_onl_build) ? low  : math.min(_onl_build, low)

if rth_just_open
    if not na(_onh_build)
        onh := _onh_build
        onl := _onl_build
    _onh_build := na
    _onl_build := na


// ═══════════════════════════════════════════════════════════════════════════
// ── ATR
// ═══════════════════════════════════════════════════════════════════════════

float atr_raw      = ta.atr(i_atr_len)
float atr_sl       = math.max(i_sl_floor, math.min(i_sl_cap, math.round(atr_raw * i_atr_mult)))
float level_buffer = math.max(4, math.round(atr_raw * 0.4))


// ═══════════════════════════════════════════════════════════════════════════
// ── VWAP + ANCHORED VWAP
// ═══════════════════════════════════════════════════════════════════════════

[vwap_val, vwap_upper, vwap_lower] = ta.vwap(hlc3, new_day, 1.0)
bool above_vwap = close > vwap_val

var float cumPV = na
var float cumV  = na
int  avwap_ts       = timestamp(avwapYear, avwapMonth, 1, 0, 0)
bool afterAnchor    = time >= avwap_ts
bool avwap_startBar = afterAnchor and not (time[1] >= avwap_ts)
if avwap_startBar
    cumPV := 0.0
    cumV  := 0.0
if afterAnchor
    cumPV += hlc3 * volume
    cumV  += volume
float avwap_val = afterAnchor and cumV > 0 ? cumPV / cumV : na

// VWAP slope — compare to 3 bars ago (15 min on 5m chart); 1.5pt threshold filters noise
string vwap_slope = vwap_val > vwap_val[3] + 1.5 ? "RISING" : vwap_val < vwap_val[3] - 1.5 ? "FALLING" : "FLAT"

// VWAP position — ±3pts = AT; beyond ±0.75×ATR = FAR; else ABOVE/BELOW
string vwap_pos   = math.abs(close - vwap_val) <= 3 ? "AT" : close > vwap_val + atr_raw * 0.75 ? "FAR_ABOVE" : close > vwap_val ? "ABOVE" : close < vwap_val - atr_raw * 0.75 ? "FAR_BELOW" : "BELOW"


// ═══════════════════════════════════════════════════════════════════════════
// ── MOVING AVERAGES
// ═══════════════════════════════════════════════════════════════════════════

float ema9   = ta.ema(close, 9)
float ema21  = ta.ema(close, 21)
float ema50  = ta.ema(close, 50)
float sma200 = ta.sma(close, 200)


// ═══════════════════════════════════════════════════════════════════════════
// ── MTF TREND CONTEXT
// ═══════════════════════════════════════════════════════════════════════════

[mtf15_bull, mtf15_rsi] = request.security(syminfo.tickerid, "15",  [ta.ema(close, 21) > ta.ema(close, 50), ta.rsi(close, 14)], lookahead=barmerge.lookahead_off)
[mtf1h_bull, mtf1h_rsi] = request.security(syminfo.tickerid, "60",  [ta.ema(close, 21) > ta.ema(close, 50), ta.rsi(close, 14)], lookahead=barmerge.lookahead_off)
[mtf4h_bull, mtf4h_rsi] = request.security(syminfo.tickerid, "240", [ta.ema(close, 21) > ta.ema(close, 50), ta.rsi(close, 14)], lookahead=barmerge.lookahead_off)

int mtf_long_bonus  = (above_vwap ? 5 : 0) + (mtf15_bull ? 5 : 0) + (mtf1h_bull ? 5 : 0) + (mtf4h_bull ? 5 : 0)
int mtf_short_bonus = (not above_vwap ? 5 : 0) + (not mtf15_bull ? 5 : 0) + (not mtf1h_bull ? 5 : 0) + (not mtf4h_bull ? 5 : 0)

// ── 3-STATE TREND DIRECTION (for webhook payload)
// ─────────────────────────────────────────────────────────────────────────────
// EMA 9 vs EMA 21 with a 0.15% neutral band eliminates crossover whipsaws.
// 5m  = current chart's own EMAs (no request.security needed)
// 15m and 1H fetched via request.security for accurate HTF alignment.
// Server receives t5/t15/t60 and uses them instead of a delayed Yahoo Finance fetch.

float mtf15_e9  = request.security(syminfo.tickerid, "15", ta.ema(close, 9),  lookahead=barmerge.lookahead_off)
float mtf15_e21 = request.security(syminfo.tickerid, "15", ta.ema(close, 21), lookahead=barmerge.lookahead_off)
float mtf1h_e9  = request.security(syminfo.tickerid, "60", ta.ema(close, 9),  lookahead=barmerge.lookahead_off)
float mtf1h_e21 = request.security(syminfo.tickerid, "60", ta.ema(close, 21), lookahead=barmerge.lookahead_off)

f_trend3(fast, slow) =>
    p = (fast - slow) / slow * 100
    p > 0.15 ? "BULLISH" : p < -0.15 ? "BEARISH" : "NEUTRAL"

string trend_5m  = f_trend3(ema9,      ema21)        // 5m = current chart
string trend_15m = f_trend3(mtf15_e9,  mtf15_e21)    // 15m via request.security
string trend_1h  = f_trend3(mtf1h_e9,  mtf1h_e21)    // 1H via request.security


// ═══════════════════════════════════════════════════════════════════════════
// ── VOLUME PROFILE (optional, off by default)
// ═══════════════════════════════════════════════════════════════════════════

float vpHi = ta.highest(high, vpLb)
float vpLo = ta.lowest(low,  vpLb)

var box[]  vpBoxes   = array.new<box>()
var line   vpPocLine = na

if i_show_vp and barstate.islast
    for b in vpBoxes
        box.delete(b)
    array.clear(vpBoxes)
    if not na(vpPocLine)
        line.delete(vpPocLine)
        vpPocLine := na
    float hi  = vpHi
    float lo  = vpLo
    float rng = hi - lo
    if rng > 0
        float binSz = rng / vpBins
        float[] vols = array.new_float(vpBins, 0.0)
        for i = 0 to vpLb - 1
            float p  = hlc3[i]
            int   bi = int((p - lo) / binSz)
            bi := bi < 0 ? 0 : bi >= vpBins ? vpBins - 1 : bi
            array.set(vols, bi, array.get(vols, bi) + volume[i])
        float maxV   = array.max(vols)
        int   pocIdx = array.indexof(vols, maxV)
        int   rightX = bar_index
        for bi = 0 to vpBins - 1
            float v      = array.get(vols, bi)
            float w      = maxV > 0 ? v / maxV : 0.0
            int   boxLen = math.max(1, int(vpLb * 0.30 * w))
            float byLo   = lo + bi * binSz
            float byHi   = byLo + binSz
            color col    = bi == pocIdx ? color.new(color.orange, 20) : color.new(color.blue, 75)
            array.push(vpBoxes, box.new(rightX - boxLen, byHi, rightX, byLo, border_color=color.new(color.black, 100), bgcolor=col))
        vpPocLine := line.new(rightX - int(vpLb * 0.30), lo + (pocIdx + 0.5) * binSz, rightX, lo + (pocIdx + 0.5) * binSz, color=color.orange, width=2)


// ═══════════════════════════════════════════════════════════════════════════
// ── HELPERS
// ═══════════════════════════════════════════════════════════════════════════

f_rej_h(lv) => (high - lv) > 0 ? math.min(1.0, (lv - close) / (high - lv)) : 0.0
f_rej_l(lv) => (lv - low)  > 0 ? math.min(1.0, (close - lv) / (lv - low))  : 0.0

f_vwap_ctx() => above_vwap ? "above" : "below"
f_mtf_ctx()  => (mtf4h_bull ? "4H:bull" : "4H:bear") + "|" + (mtf1h_bull ? "1H:bull" : "1H:bear") + "|" + (mtf15_bull ? "15m:bull" : "15m:bear")

f_json(setup, entry, sl, tp1, tp2, notes) =>
    '{"secret":"' + i_secret + '","symbol":"' + i_symbol + '","timeframe":"' + timeframe.period + '","setup":"' + setup + '","entry":' + str.tostring(math.round(entry, 2)) + ',"sl":' + str.tostring(math.round(sl, 2)) + ',"tp1":' + str.tostring(math.round(tp1, 2)) + ',"tp2":' + str.tostring(math.round(tp2, 2)) + ',"vwap":"' + f_vwap_ctx() + '","mtf":"' + f_mtf_ctx() + '","t5":"' + trend_5m + '","t15":"' + trend_15m + '","t60":"' + trend_1h + '","vp":' + str.tostring(math.round(vwap_val, 2)) + ',"vslope":"' + vwap_slope + '","vpos":"' + vwap_pos + '","pdh":' + (na(pdh) ? 'null' : str.tostring(math.round(pdh, 2))) + ',"pdl":' + (na(pdl) ? 'null' : str.tostring(math.round(pdl, 2))) + ',"pdc":' + (na(pdc) ? 'null' : str.tostring(math.round(pdc, 2))) + ',"onh":' + (na(onh) ? 'null' : str.tostring(math.round(onh, 2))) + ',"onl":' + (na(onl) ? 'null' : str.tostring(math.round(onl, 2))) + ',"orh":' + (na(orh) ? 'null' : str.tostring(math.round(orh, 2))) + ',"orl":' + (na(orl) ? 'null' : str.tostring(math.round(orl, 2))) + ',"pmh":' + (na(pmh) ? 'null' : str.tostring(math.round(pmh, 2))) + ',"pml":' + (na(pml) ? 'null' : str.tostring(math.round(pml, 2))) + ',"atr":' + str.tostring(math.round(atr_raw, 2)) + ',"notes":"' + notes + '"}'

f_tp1_long (e, sl) => e + math.abs(e - sl) * 1.5
f_tp2_long (e, sl) => e + math.abs(e - sl) * 3.0
f_tp1_short(e, sl) => e - math.abs(sl - e) * 1.5
f_tp2_short(e, sl) => e - math.abs(sl - e) * 3.0


// ═══════════════════════════════════════════════════════════════════════════
// ── SWEEP DETECTION  (with optional VWAP filter)
// ═══════════════════════════════════════════════════════════════════════════

bool vwap_ok_short = not i_vwap_filt or not above_vwap
bool vwap_ok_long  = not i_vwap_filt or above_vwap
bool body_bear     = close < (high + low) / 2
bool body_bull     = close > (high + low) / 2

bool pdh_ok        = not na(pdh)
bool pdh_swept     = pdh_ok and (high - pdh) >= i_min_sweep
bool pdh_rejected  = pdh_swept and close < pdh
float pdh_rej      = pdh_swept ? f_rej_h(pdh) : 0.0
bool sig_pdh_short = pdh_rejected and pdh_rej >= i_min_rej and body_bear and barstate.isconfirmed and in_session and vwap_ok_short

bool pdl_ok        = not na(pdl)
bool pdl_swept     = pdl_ok and (pdl - low) >= i_min_sweep
bool pdl_rejected  = pdl_swept and close > pdl
float pdl_rej      = pdl_swept ? f_rej_l(pdl) : 0.0
bool sig_pdl_long  = pdl_rejected and pdl_rej >= i_min_rej and body_bull and barstate.isconfirmed and in_session and vwap_ok_long

bool onh_ok        = not na(onh)
bool onh_swept     = onh_ok and (high - onh) >= i_min_sweep
bool onh_rejected  = onh_swept and close < onh
float onh_rej      = onh_swept ? f_rej_h(onh) : 0.0
bool sig_onh_short = onh_rejected and onh_rej >= i_min_rej and body_bear and barstate.isconfirmed and in_session and vwap_ok_short

bool onl_ok        = not na(onl)
bool onl_swept     = onl_ok and (onl - low) >= i_min_sweep
bool onl_rejected  = onl_swept and close > onl
float onl_rej      = onl_swept ? f_rej_l(onl) : 0.0
bool sig_onl_long  = onl_rejected and onl_rej >= i_min_rej and body_bull and barstate.isconfirmed and in_session and vwap_ok_long

bool orh_ok        = not na(orh) and or_ready
bool orh_swept     = orh_ok and (high - orh) >= i_min_sweep
bool orh_rejected  = orh_swept and close < orh
float orh_rej      = orh_swept ? f_rej_h(orh) : 0.0
bool sig_orh_short = orh_rejected and orh_rej >= i_min_rej and body_bear and barstate.isconfirmed and in_session and vwap_ok_short

bool orl_ok        = not na(orl) and or_ready
bool orl_swept     = orl_ok and (orl - low) >= i_min_sweep
bool orl_rejected  = orl_swept and close > orl
float orl_rej      = orl_swept ? f_rej_l(orl) : 0.0
bool sig_orl_long  = orl_rejected and orl_rej >= i_min_rej and body_bull and barstate.isconfirmed and in_session and vwap_ok_long

bool pmh_ok        = not na(pmh)
bool pmh_swept     = pmh_ok and (high - pmh) >= i_min_sweep
bool pmh_rejected  = pmh_swept and close < pmh
float pmh_rej      = pmh_swept ? f_rej_h(pmh) : 0.0
bool sig_pmh_short = pmh_rejected and pmh_rej >= i_min_rej and body_bear and barstate.isconfirmed and in_session and vwap_ok_short

bool pml_ok        = not na(pml)
bool pml_swept     = pml_ok and (pml - low) >= i_min_sweep
bool pml_rejected  = pml_swept and close > pml
float pml_rej      = pml_swept ? f_rej_l(pml) : 0.0
bool sig_pml_long  = pml_rejected and pml_rej >= i_min_rej and body_bull and barstate.isconfirmed and in_session and vwap_ok_long


// ═══════════════════════════════════════════════════════════════════════════
// ── PLAYBOOK DEDUPLICATION  (each fires once per day max)
// ═══════════════════════════════════════════════════════════════════════════

var bool orb_l_fired    = false
var bool orb_s_fired    = false
var bool onh_brk_fired  = false
var bool onl_brk_fired  = false
var bool btp_fired      = false
var bool betp_fired     = false

if new_day
    orb_l_fired   := false
    orb_s_fired   := false
    onh_brk_fired := false
    onl_brk_fired := false
    btp_fired     := false
    betp_fired    := false


// ═══════════════════════════════════════════════════════════════════════════
// ── PLAYBOOK DETECTION  (+5 bonus each: VWAP / 1H / 4H alignment)
// ═══════════════════════════════════════════════════════════════════════════

float avg_vol    = ta.sma(volume, 30)
float vol_ratio  = avg_vol > 0 ? volume / avg_vol : 1.0

float half1_avg  = math.avg(close[15], close[14], close[13], close[12], close[11], close[10], close[9], close[8])
float half2_avg  = math.avg(close[7],  close[6],  close[5],  close[4],  close[3],  close[2],  close[1],  close)
float trend_diff = half2_avg - half1_avg
bool trend_bull  = trend_diff > 25
bool trend_bear  = trend_diff < -25

float orb_l_score = (or_ready and not na(orh) and close > orh ? 40 : 0) + (close > open ? 20 : 0) + (not na(orh) and close > orh + 5 ? 15 : 0) + (not na(orh) and close[1] <= orh and close[2] <= orh ? 15 : 0) + (vol_ratio >= 1.0 ? 10 : 0) + mtf_long_bonus
bool sig_orb_long = orb_l_score >= 55 and barstate.isconfirmed and in_session and not orb_l_fired

float orb_s_score = (or_ready and not na(orl) and close < orl ? 40 : 0) + (close < open ? 20 : 0) + (not na(orl) and close < orl - 5 ? 15 : 0) + (not na(orl) and close[1] >= orl and close[2] >= orl ? 15 : 0) + (vol_ratio >= 1.0 ? 10 : 0) + mtf_short_bonus
bool sig_orb_short = orb_s_score >= 55 and barstate.isconfirmed and in_session and not orb_s_fired

float onh_brk_score = (not na(onh) and close > onh ? 30 : 0) + (not na(pdh) and close > pdh ? 25 : 0) + (not na(onh) and close[1] > onh ? 25 : 0) + (close > open ? 20 : 0) + mtf_long_bonus
bool sig_onh_break_long = onh_brk_score >= 55 and barstate.isconfirmed and in_session and not onh_brk_fired

float onl_brk_score = (not na(onl) and close < onl ? 30 : 0) + (not na(pdl) and close < pdl ? 25 : 0) + (not na(onl) and close[1] < onl ? 25 : 0) + (close < open ? 20 : 0) + mtf_short_bonus
bool sig_onl_break_short = onl_brk_score >= 55 and barstate.isconfirmed and in_session and not onl_brk_fired

float rec_hi5   = math.max(high, math.max(high[1], math.max(high[2], math.max(high[3], high[4]))))
float rec_lo5   = math.min(low,  math.min(low[1],  math.min(low[2],  math.min(low[3],  low[4]))))
float rec_range = rec_hi5 - rec_lo5
bool at_support = (not na(onl) and math.abs(low - onl) <= 15) or (not na(orl) and math.abs(low - orl) <= 15) or (not na(pdc) and math.abs(low - pdc) <= 15)
float btp_score = (trend_bull ? 30 : 0) + (close < rec_hi5 - 10 ? 25 : 0) + (close > open ? 25 : 0) + (rec_range > 0 and (rec_hi5 - close) / rec_range < 0.6 ? 10 : 0) + (at_support ? 10 : 0) + mtf_long_bonus
bool sig_bull_pullback = btp_score >= 55 and barstate.isconfirmed and in_session and not btp_fired

bool at_resist = (not na(onh) and math.abs(high - onh) <= 15) or (not na(orh) and math.abs(high - orh) <= 15) or (not na(pdc) and math.abs(high - pdc) <= 15)
float betp_score = (trend_bear ? 30 : 0) + (close > rec_lo5 + 10 ? 25 : 0) + (close < open ? 25 : 0) + (rec_range > 0 and (close - rec_lo5) / rec_range < 0.6 ? 10 : 0) + (at_resist ? 10 : 0) + mtf_short_bonus
bool sig_bear_pullback = betp_score >= 55 and barstate.isconfirmed and in_session and not betp_fired

// Lock fired flags after first fire (resets each new_day above)
if sig_orb_long
    orb_l_fired := true
if sig_orb_short
    orb_s_fired := true
if sig_onh_break_long
    onh_brk_fired := true
if sig_onl_break_short
    onl_brk_fired := true
if sig_bull_pullback
    btp_fired := true
if sig_bear_pullback
    betp_fired := true


// ═══════════════════════════════════════════════════════════════════════════
// ── WEBHOOK ALERTS
// ═══════════════════════════════════════════════════════════════════════════

if sig_pdh_short
    _sl = pdh + level_buffer
    alert(f_json("PDH_SWEEP_REVERSAL_SHORT", close, _sl, f_tp1_short(close, _sl), f_tp2_short(close, _sl), "PDH swept " + str.tostring(math.round(high - pdh, 1)) + "pts rej=" + str.tostring(math.round(pdh_rej * 100)) + "%"), alert.freq_once_per_bar_close)

if sig_pdl_long
    _sl = pdl - level_buffer
    alert(f_json("PDL_SWEEP_REVERSAL_LONG", close, _sl, f_tp1_long(close, _sl), f_tp2_long(close, _sl), "PDL swept " + str.tostring(math.round(pdl - low, 1)) + "pts rej=" + str.tostring(math.round(pdl_rej * 100)) + "%"), alert.freq_once_per_bar_close)

if sig_onh_short
    _sl = onh + level_buffer
    alert(f_json("ONH_SWEEP_REVERSAL_SHORT", close, _sl, f_tp1_short(close, _sl), f_tp2_short(close, _sl), "ONH swept " + str.tostring(math.round(high - onh, 1)) + "pts rej=" + str.tostring(math.round(onh_rej * 100)) + "%"), alert.freq_once_per_bar_close)

if sig_onl_long
    _sl = onl - level_buffer
    alert(f_json("ONL_SWEEP_REVERSAL_LONG", close, _sl, f_tp1_long(close, _sl), f_tp2_long(close, _sl), "ONL swept " + str.tostring(math.round(onl - low, 1)) + "pts rej=" + str.tostring(math.round(onl_rej * 100)) + "%"), alert.freq_once_per_bar_close)

if sig_orh_short
    _sl = orh + level_buffer
    alert(f_json("ORH_SWEEP_REVERSAL_SHORT", close, _sl, f_tp1_short(close, _sl), f_tp2_short(close, _sl), "ORH swept " + str.tostring(math.round(high - orh, 1)) + "pts rej=" + str.tostring(math.round(orh_rej * 100)) + "%"), alert.freq_once_per_bar_close)

if sig_orl_long
    _sl = orl - level_buffer
    alert(f_json("ORL_SWEEP_REVERSAL_LONG", close, _sl, f_tp1_long(close, _sl), f_tp2_long(close, _sl), "ORL swept " + str.tostring(math.round(orl - low, 1)) + "pts rej=" + str.tostring(math.round(orl_rej * 100)) + "%"), alert.freq_once_per_bar_close)

if sig_pmh_short
    _sl = pmh + level_buffer
    alert(f_json("PMH_SWEEP_REVERSAL_SHORT", close, _sl, f_tp1_short(close, _sl), f_tp2_short(close, _sl), "PMH swept " + str.tostring(math.round(high - pmh, 1)) + "pts rej=" + str.tostring(math.round(pmh_rej * 100)) + "%"), alert.freq_once_per_bar_close)

if sig_pml_long
    _sl = pml - level_buffer
    alert(f_json("PML_SWEEP_REVERSAL_LONG", close, _sl, f_tp1_long(close, _sl), f_tp2_long(close, _sl), "PML swept " + str.tostring(math.round(pml - low, 1)) + "pts rej=" + str.tostring(math.round(pml_rej * 100)) + "%"), alert.freq_once_per_bar_close)

if sig_orb_long
    _sl = (not na(orl) ? orl : close) - atr_sl
    alert(f_json("BULLISH_ORB_LONG", close, _sl, f_tp1_long(close, _sl), f_tp2_long(close, _sl), "ORB break " + str.tostring(math.round(close - orh, 1)) + "pts above ORH | vol=" + str.tostring(math.round(vol_ratio, 1)) + "x | score=" + str.tostring(orb_l_score)), alert.freq_once_per_bar_close)

if sig_orb_short
    _sl = (not na(orh) ? orh : close) + atr_sl
    alert(f_json("BEARISH_ORB_SHORT", close, _sl, f_tp1_short(close, _sl), f_tp2_short(close, _sl), "ORB break " + str.tostring(math.round(orl - close, 1)) + "pts below ORL | vol=" + str.tostring(math.round(vol_ratio, 1)) + "x | score=" + str.tostring(orb_s_score)), alert.freq_once_per_bar_close)

if sig_onh_break_long
    _sl = (not na(onh) ? onh : close) - atr_sl
    alert(f_json("ONH_BREAKOUT_CONTINUATION_LONG", close, _sl, f_tp1_long(close, _sl), f_tp2_long(close, _sl), "ONH breakout " + str.tostring(math.round(close - onh, 1)) + "pts | score=" + str.tostring(onh_brk_score)), alert.freq_once_per_bar_close)

if sig_onl_break_short
    _sl = (not na(onl) ? onl : close) + atr_sl
    alert(f_json("ONL_BREAKDOWN_CONTINUATION_SHORT", close, _sl, f_tp1_short(close, _sl), f_tp2_short(close, _sl), "ONL breakdown " + str.tostring(math.round(onl - close, 1)) + "pts | score=" + str.tostring(onl_brk_score)), alert.freq_once_per_bar_close)

if sig_bull_pullback
    _sl = close - atr_sl
    alert(f_json("BULLISH_TREND_PULLBACK_LONG", close, _sl, f_tp1_long(close, _sl), f_tp2_long(close, _sl), "Bull pullback | trend=" + str.tostring(math.round(trend_diff, 1)) + " | score=" + str.tostring(btp_score)), alert.freq_once_per_bar_close)

if sig_bear_pullback
    _sl = close + atr_sl
    alert(f_json("BEARISH_TREND_PULLBACK_SHORT", close, _sl, f_tp1_short(close, _sl), f_tp2_short(close, _sl), "Bear pullback | trend=" + str.tostring(math.round(trend_diff, 1)) + " | score=" + str.tostring(betp_score)), alert.freq_once_per_bar_close)


// ═══════════════════════════════════════════════════════════════════════════
// ── VISUAL DISPLAY
// ═══════════════════════════════════════════════════════════════════════════

bgcolor(inAsia ? color.new(color.yellow, 92) : na, title="Asia Kill Zone")
bgcolor(inLon  ? color.new(color.blue,   90) : na, title="London Kill Zone")
bgcolor(inNY   ? color.new(color.green,  90) : na, title="NY Kill Zone")

plot(i_show_ma ? ema9   : na, "EMA 9",   color=color.new(color.aqua,    0), linewidth=1)
plot(i_show_ma ? ema21  : na, "EMA 21",  color=color.new(color.orange,  0), linewidth=1)
plot(i_show_ma ? ema50  : na, "EMA 50",  color=color.new(color.yellow,  0), linewidth=2)
plot(i_show_ma ? sma200 : na, "SMA 200", color=color.new(color.fuchsia, 0), linewidth=2)

plot(i_show_vwap ? vwap_val   : na, "VWAP",       color=color.new(color.blue,   0),  linewidth=2)
plot(i_show_vwap ? vwap_upper : na, "VWAP +1σ",   color=color.new(color.blue,   60), linewidth=1)
plot(i_show_vwap ? vwap_lower : na, "VWAP -1σ",   color=color.new(color.blue,   60), linewidth=1)
plot(i_show_vwap ? avwap_val  : na, "Anch. VWAP", color=color.new(color.purple, 0),  linewidth=2, style=plot.style_linebr)

plot(i_show_lvl ? pdh : na, "PDH", color=color.new(color.red,    20), linewidth=1, style=plot.style_circles)
plot(i_show_lvl ? pdl : na, "PDL", color=color.new(color.green,  20), linewidth=1, style=plot.style_circles)
plot(i_show_lvl ? pdc : na, "PDC", color=color.new(color.gray,   40), linewidth=1, style=plot.style_circles)
plot(i_show_lvl ? onh : na, "ONH", color=color.new(color.orange, 30), linewidth=1, style=plot.style_circles)
plot(i_show_lvl ? onl : na, "ONL", color=color.new(color.teal,   30), linewidth=1, style=plot.style_circles)
plot(i_show_lvl ? orh : na, "ORH", color=color.new(color.blue,   30), linewidth=1, style=plot.style_circles)
plot(i_show_lvl ? orl : na, "ORL", color=color.new(color.purple, 30), linewidth=1, style=plot.style_circles)
plot(i_show_lvl ? pmh : na, "PMH", color=color.new(color.yellow, 40), linewidth=1, style=plot.style_circles)
plot(i_show_lvl ? pml : na, "PML", color=color.new(color.lime,   40), linewidth=1, style=plot.style_circles)

if i_show_lbl
    if sig_pdh_short
        label.new(bar_index, high, "▼ PDH SHORT",  yloc=yloc.abovebar, color=color.red,    textcolor=color.white, style=label.style_label_down, size=size.small)
    if sig_onh_short
        label.new(bar_index, high, "▼ ONH SHORT",  yloc=yloc.abovebar, color=color.red,    textcolor=color.white, style=label.style_label_down, size=size.small)
    if sig_orh_short
        label.new(bar_index, high, "▼ ORH SHORT",  yloc=yloc.abovebar, color=color.orange, textcolor=color.white, style=label.style_label_down, size=size.small)
    if sig_pmh_short
        label.new(bar_index, high, "▼ PMH SHORT",  yloc=yloc.abovebar, color=color.maroon, textcolor=color.white, style=label.style_label_down, size=size.small)
    if sig_pdl_long
        label.new(bar_index, low,  "▲ PDL LONG",   yloc=yloc.belowbar, color=color.green,  textcolor=color.white, style=label.style_label_up,   size=size.small)
    if sig_onl_long
        label.new(bar_index, low,  "▲ ONL LONG",   yloc=yloc.belowbar, color=color.green,  textcolor=color.white, style=label.style_label_up,   size=size.small)
    if sig_orl_long
        label.new(bar_index, low,  "▲ ORL LONG",   yloc=yloc.belowbar, color=color.teal,   textcolor=color.white, style=label.style_label_up,   size=size.small)
    if sig_pml_long
        label.new(bar_index, low,  "▲ PML LONG",   yloc=yloc.belowbar, color=color.lime,   textcolor=color.white, style=label.style_label_up,   size=size.small)
    if sig_orb_long
        label.new(bar_index, low,  "▲ ORB LONG",   yloc=yloc.belowbar, color=color.blue,   textcolor=color.white, style=label.style_label_up,   size=size.normal)
    if sig_orb_short
        label.new(bar_index, high, "▼ ORB SHORT",  yloc=yloc.abovebar, color=color.blue,   textcolor=color.white, style=label.style_label_down, size=size.normal)
    if sig_onh_break_long
        label.new(bar_index, low,  "▲ ONH BRK",    yloc=yloc.belowbar, color=color.purple, textcolor=color.white, style=label.style_label_up,   size=size.small)
    if sig_onl_break_short
        label.new(bar_index, high, "▼ ONL BRK",    yloc=yloc.abovebar, color=color.purple, textcolor=color.white, style=label.style_label_down, size=size.small)
    if sig_bull_pullback
        label.new(bar_index, low,  "▲ BULL PB",    yloc=yloc.belowbar, color=color.green,  textcolor=color.white, style=label.style_label_up,   size=size.small)
    if sig_bear_pullback
        label.new(bar_index, high, "▼ BEAR PB",    yloc=yloc.abovebar, color=color.red,    textcolor=color.white, style=label.style_label_down, size=size.small)


// ═══════════════════════════════════════════════════════════════════════════
// ── MTF TREND DASHBOARD
// ═══════════════════════════════════════════════════════════════════════════

color upBg_d = color.new(#26a69a, 70)
color dnBg_d = color.new(#ef5350, 70)
color upTx_d = color.new(#26a69a, 0)
color dnTx_d = color.new(#ef5350, 0)

f_dbRow(t, r, tf, bull, rsiv) =>
    table.cell(t, 0, r, tf,                         text_color=color.white,                            text_size=size.small)
    table.cell(t, 1, r, bull ? "▲ Bull" : "▼ Bear", text_color=color.white, bgcolor=bull ? upBg_d : dnBg_d, text_size=size.small)
    table.cell(t, 2, r, str.tostring(rsiv, "#.0"),   text_color=rsiv > 50 ? upTx_d : dnTx_d,           text_size=size.small)

var table mtfDash = na
if i_show_mtf and barstate.islast
    if na(mtfDash)
        mtfDash := table.new(position.top_right, 3, 5, border_width=1)
    table.cell(mtfDash, 0, 0, "TF",    text_color=color.white, bgcolor=color.new(color.gray, 30), text_size=size.small)
    table.cell(mtfDash, 1, 0, "Trend", text_color=color.white, bgcolor=color.new(color.gray, 30), text_size=size.small)
    table.cell(mtfDash, 2, 0, "RSI",   text_color=color.white, bgcolor=color.new(color.gray, 30), text_size=size.small)
    f_dbRow(mtfDash, 1, "15m", mtf15_bull, mtf15_rsi)
    f_dbRow(mtfDash, 2, "1H",  mtf1h_bull, mtf1h_rsi)
    f_dbRow(mtfDash, 3, "4H",  mtf4h_bull, mtf4h_rsi)
    table.cell(mtfDash, 0, 4, "VWAP",                                        text_color=color.white,                            text_size=size.small)
    table.cell(mtfDash, 1, 4, above_vwap ? "▲ Above" : "▼ Below",           text_color=color.white, bgcolor=above_vwap ? upBg_d : dnBg_d, text_size=size.small)
    table.cell(mtfDash, 2, 4, str.tostring(math.round(close - vwap_val, 1)), text_color=above_vwap ? upTx_d : dnTx_d,           text_size=size.small)


// ═══════════════════════════════════════════════════════════════════════════
// ── NAMED ALERT CONDITIONS
// ═══════════════════════════════════════════════════════════════════════════

bool any_signal = sig_pdh_short or sig_pdl_long or sig_onh_short or sig_onl_long or
                  sig_orh_short or sig_orl_long or sig_pmh_short or sig_pml_long or
                  sig_orb_long  or sig_orb_short or
                  sig_onh_break_long or sig_onl_break_short or
                  sig_bull_pullback  or sig_bear_pullback

alertcondition(any_signal,          "Any NQ Signal",                    "NQ setup detected")
alertcondition(sig_pdh_short,       "PDH Sweep Reversal SHORT",         "PDH SHORT")
alertcondition(sig_pdl_long,        "PDL Sweep Reversal LONG",          "PDL LONG")
alertcondition(sig_onh_short,       "ONH Sweep Reversal SHORT",         "ONH SHORT")
alertcondition(sig_onl_long,        "ONL Sweep Reversal LONG",          "ONL LONG")
alertcondition(sig_orh_short,       "ORH Sweep Reversal SHORT",         "ORH SHORT")
alertcondition(sig_orl_long,        "ORL Sweep Reversal LONG",          "ORL LONG")
alertcondition(sig_pmh_short,       "PMH Sweep Reversal SHORT",         "PMH SHORT")
alertcondition(sig_pml_long,        "PML Sweep Reversal LONG",          "PML LONG")
alertcondition(sig_orb_long,        "Bullish ORB LONG",                 "ORB LONG")
alertcondition(sig_orb_short,       "Bearish ORB SHORT",                "ORB SHORT")
alertcondition(sig_onh_break_long,  "ONH Breakout Continuation LONG",   "ONH Breakout LONG")
alertcondition(sig_onl_break_short, "ONL Breakdown Continuation SHORT",  "ONL Breakdown SHORT")
alertcondition(sig_bull_pullback,   "Bullish Trend Pullback LONG",      "Bull Pullback LONG")
alertcondition(sig_bear_pullback,   "Bearish Trend Pullback SHORT",     "Bear Pullback SHORT")
